{% extends 'base.html.twig' %}

{% block title %}Панель преподавателя{% endblock %}

{% block stylesheets %}
<style>
    body {
        background-color: #f8f9fa;
    }
    
    .sidebar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        min-height: 100vh;
        position: fixed;
        width: 250px;
    }
    
    .main-content {
        margin-left: 250px;
        padding: 20px;
    }
    
    .test-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        padding: 20px;
        transition: transform 0.2s;
    }
    
    .test-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.15);
    }
    
    .btn-action {
        margin-right: 5px;
    }
</style>
{% endblock %}

{% block body %}
<div class="sidebar">
    <div class="p-4">
        <h3 class="mb-4">
            <i class="bi bi-person-circle"></i>
            Преподаватель
        </h3>
        <div class="mb-4">
            {% if app.user %}
                <h5>{{ app.user.firstName }} {{ app.user.lastName }}</h5>
                <small>Группа: преподаватель</small>
            {% endif %}
        </div>
        <hr class="bg-light">
        <ul class="nav nav-pills flex-column">
            <li class="nav-item">
                <a href="{{ path('app_teacher_panel') }}" class="nav-link active text-white bg-transparent">
                    <i class="bi bi-list-task"></i> Тесты
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('app_teacher_students') }}" class="nav-link text-white">
                    <i class="bi bi-people"></i> Студенты
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('app_teacher_statistics') }}" class="nav-link text-white">
                    <i class="bi bi-bar-chart"></i> Статистика
                </a>
            </li>
        </ul>
    </div>
    <div class="position-absolute bottom-0 p-4 w-100">
        <a href="{{ path('app_logout') }}" class="btn btn-outline-light w-100">
            <i class="bi bi-box-arrow-right"></i> Выйти
        </a>
    </div>
</div>

<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Управление тестами</h1>
        <a href="{{ path('app_teacher_test_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Создать тест
        </a>
    </div>
    
    <div class="row" id="testsList">
        {% for test in tests %}
            <div class="col-md-6">
                <div class="test-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h4>{{ test.title }}</h4>
                            <p class="text-muted mb-2">{{ test.description }}</p>
                            <small class="text-muted">
                                Вопросов: {{ test.questions|length }} | 
                                Дата создания: {{ test.createdAt|date('d.m.Y') }}
                            </small>
                        </div>
                        <div class="btn-group">
                            <a href="{{ path('app_teacher_test_edit', {'id': test.id}) }}" class="btn btn-sm btn-outline-primary btn-action">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('app_teacher_test_delete', {'id': test.id}) }}" style="display:inline;" onsubmit="return confirm('Удалить тест?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ test.id) }}">
                                <button class="btn btn-sm btn-outline-danger btn-action">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-info">{{ test.createdBy.firstName ?? 'Автор' }}</span>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">
                    Пока нет созданных тестов. Создайте первый тест!
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}