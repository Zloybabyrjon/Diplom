<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель преподавателя</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        
        .sidebar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            min-height: 100vh;
            position: fixed;
            width: 250px;
        }
        
        .main-content {
            margin-left: 250px;
            padding: 20px;
        }
        
        .test-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            padding: 20px;
            transition: transform 0.2s;
        }
        
        .test-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }
        
        .btn-action {
            margin-right: 5px;
        }
        
        .modal-content {
            border-radius: 15px;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="p-4">
            <h3 class="mb-4">
                <i class="bi bi-person-circle"></i>
                Преподаватель
            </h3>
            <div class="mb-4">
                {% if app.user %}
                    <h5>{{ app.user.firstName ?? 'Имя' }} {{ app.user.lastName ?? 'Фамилия' }}</h5>
                    <small>Группа: преподаватель</small>
                {% else %}
                    <h5>Демо-преподаватель</h5>
                    <small>Группа: преподаватель</small>
                {% endif %}
            </div>
            <hr class="bg-light">
            <ul class="nav nav-pills flex-column">
                <li class="nav-item">
                    <a href="#" class="nav-link active text-white bg-transparent">
                        <i class="bi bi-list-task"></i> Тесты
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link text-white">
                        <i class="bi bi-people"></i> Студенты
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link text-white">
                        <i class="bi bi-bar-chart"></i> Статистика
                    </a>
                </li>
            </ul>
        </div>
        <div class="position-absolute bottom-0 p-4 w-100">
            {% if app.user %}
                <a href="{{ path('app_logout') }}" class="btn btn-outline-light w-100">
                    <i class="bi bi-box-arrow-right"></i> Выйти
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-outline-light w-100">
                    <i class="bi bi-box-arrow-in-right"></i> Войти
                </a>
            {% endif %}
        </div>
    </div>
    
    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Управление тестами</h1>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTestModal">
                <i class="bi bi-plus-circle"></i> Создать тест
            </button>
        </div>
        
        <div class="row" id="testsList">
            {% for test in tests %}
                <div class="col-md-6">
                    <div class="test-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4>{{ test.title }}</h4>
                                <p class="text-muted mb-2">{{ test.description }}</p>
                                <small class="text-muted">
                                    Вопросов: {{ test.questionCount }} | 
                                    Дата создания: {{ test.createdAt|date('d.m.Y') }}
                                </small>
                            </div>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-primary btn-action"
                                        onclick="editTest({{ test.id }})">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-action"
                                        onclick="deleteTest({{ test.id }})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="mt-3">
                            <span class="badge bg-info">{{ test.subject }}</span>
                            <span class="badge bg-secondary">{{ test.group }}</span>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">
                        Пока нет созданных тестов. Создайте первый тест!
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    
    <!-- Модальное окно создания теста -->
    <div class="modal fade" id="createTestModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Создание нового теста</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="createTestForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Название теста</label>
                            <input type="text" class="form-control" name="title" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea class="form-control" name="description" rows="3"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Предмет</label>
                                    <input type="text" class="form-control" name="subject" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Для группы</label>
                                    <select class="form-select" name="group" required>
                                        <option value="all">Все группы</option>
                                        <option value="ПИ-20-1">ПИ-20-1</option>
                                        <option value="ПИ-20-2">ПИ-20-2</option>
                                        <option value="ИВТ-20-1">ИВТ-20-1</option>
                                        <option value="ИВТ-20-2">ИВТ-20-2</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Добавить вопрос</label>
                            <div class="border p-3 rounded mb-3" id="questionsContainer">
                                <div class="question-item mb-3">
                                    <input type="text" class="form-control mb-2" placeholder="Текст вопроса" required>
                                    <div class="answers-container">
                                        <div class="input-group mb-2">
                                            <div class="input-group-text">
                                                <input class="form-check-input mt-0" type="radio" name="correctAnswer" value="0">
                                            </div>
                                            <input type="text" class="form-control" placeholder="Вариант ответа 1" required>
                                        </div>
                                        <div class="input-group mb-2">
                                            <div class="input-group-text">
                                                <input class="form-check-input mt-0" type="radio" name="correctAnswer" value="1">
                                            </div>
                                            <input type="text" class="form-control" placeholder="Вариант ответа 2" required>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addAnswer(this)">
                                        Добавить вариант ответа
                                    </button>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-primary w-100" onclick="addQuestion()">
                                <i class="bi bi-plus"></i> Добавить еще вопрос
                            </button>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">Создать тест</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let questionCount = 1;
        
        function addQuestion() {
            const container = document.getElementById('questionsContainer');
            const questionItem = document.createElement('div');
            questionItem.className = 'question-item mb-3 border p-3 rounded';
            questionItem.innerHTML = `
                <h6>Вопрос ${++questionCount}</h6>
                <input type="text" class="form-control mb-2" placeholder="Текст вопроса" required>
                <div class="answers-container">
                    <div class="input-group mb-2">
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correctAnswer${questionCount}" value="0">
                        </div>
                        <input type="text" class="form-control" placeholder="Вариант ответа 1" required>
                    </div>
                    <div class="input-group mb-2">
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correctAnswer${questionCount}" value="1">
                        </div>
                        <input type="text" class="form-control" placeholder="Вариант ответа 2" required>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addAnswer(this)">
                    Добавить вариант ответа
                </button>
            `;
            container.appendChild(questionItem);
        }
        
        function addAnswer(button) {
            const answersContainer = button.previousElementSibling;
            const answerIndex = answersContainer.children.length;
            const answerDiv = document.createElement('div');
            answerDiv.className = 'input-group mb-2';
            answerDiv.innerHTML = `
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="radio" name="${button.closest('.question-item').querySelector('input[type="radio"]').name}" value="${answerIndex}">
                </div>
                <input type="text" class="form-control" placeholder="Вариант ответа ${answerIndex + 1}" required>
            `;
            answersContainer.appendChild(answerDiv);
        }
        
        function editTest(testId) {
            alert('Редактирование теста ' + testId);
            // Здесь будет логика редактирования
        }
        
        function deleteTest(testId) {
            if (confirm('Вы уверены, что хотите удалить этот тест?')) {
                // Здесь будет логика удаления
                alert('Тест удален (заглушка)');
            }
        }
        
        document.getElementById('createTestForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Тест создан (заглушка)');
            const modal = bootstrap.Modal.getInstance(document.getElementById('createTestModal'));
            modal.hide();
        });
    </script>
</body>
</html>