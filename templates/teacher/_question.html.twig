<div class="question-card" data-index="{{ index }}">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Вопрос <span class="question-number">{{ index + 1 }}</span></h5>
        <span class="remove-btn" onclick="removeQuestion(this)">✖ Удалить вопрос</span>
    </div>
    <div class="mb-3">
        <label class="form-label">Текст вопроса</label>
        <input type="text" class="form-control" name="questions[{{ index }}][text]" value="{{ question.questionText }}" required>
    </div>
    <div class="mb-3">
    <label class="form-label">Изображение</label>
    {% if question.image %}
        <div class="mb-2">
            <img src="{{ asset('uploads/questions/' ~ question.image) }}" alt="Изображение вопроса" style="max-width: 200px; max-height: 150px;">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="questions[{{ index }}][delete_image]" value="1" id="delete_image_{{ index }}">
                <label class="form-check-label" for="delete_image_{{ index }}">Удалить текущее изображение</label>
            </div>
        </div>
    {% endif %}
    <input type="file" class="form-control" name="questions[{{ index }}][image]" accept="image/*">
    <div class="form-text">Загрузите новое изображение, чтобы заменить текущее.</div>
</div>
        <div class="col-md-6">
            <label class="form-label">Баллы</label>
            <input type="number" class="form-control" name="questions[{{ index }}][points]" value="{{ question.points }}" min="1" step="1">
        </div>
    </div>
    <div class="answers-container">
        <label class="form-label">Варианты ответов</label>
        {% for answer in question.answers %}
            <div class="answer-item">
                <input type="text" class="form-control" name="questions[{{ index }}][answers][{{ loop.index0 }}]" value="{{ answer.answerText }}" required>
                <input type="checkbox" name="questions[{{ index }}][correct][]" value="{{ loop.index0 }}" {{ answer.isCorrect ? 'checked' : '' }} title="Правильный">
                <span class="remove-btn" onclick="removeAnswer(this)">✖</span>
            </div>
        {% endfor %}
    </div>
    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addAnswer(this, {{ index }})">
        <i class="bi bi-plus"></i> Добавить ответ
    </button>
</div>