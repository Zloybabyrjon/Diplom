{% extends 'base.html.twig' %}

{% block title %}Админ панель{% endblock %}

{% block stylesheets %}
<style>
    .admin-sidebar {
        background: #343a40;
        min-height: 100vh;
        color: white;
        position: fixed;
        width: 250px;
        left: 0;
        top: 0;
    }
    
    .admin-content {
        margin-left: 250px;
        padding: 30px;
    }
    
    .stat-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #6c757d;
        display: inline-block;
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-sidebar">
    <div class="p-4">
        <h4 class="mb-4">
            <i class="bi bi-shield-lock"></i> Админ панель
        </h4>
        <hr class="bg-light">
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a href="#dashboard" class="nav-link text-white active" data-bs-toggle="pill">
                    <i class="bi bi-speedometer2"></i> Дашборд
                </a>
            </li>
            <li class="nav-item mb-2">
                <a href="#users" class="nav-link text-white" data-bs-toggle="pill">
                    <i class="bi bi-people"></i> Пользователи
                </a>
            </li>
            <li class="nav-item mb-2">
                <a href="#tests" class="nav-link text-white" data-bs-toggle="pill">
                    <i class="bi bi-list-task"></i> Тесты
                </a>
            </li>
            <li class="nav-item mb-2">
                <a href="#categories" class="nav-link text-white" data-bs-toggle="pill">
                    <i class="bi bi-tags"></i> Категории
                </a>
            </li>
            <li class="nav-item mb-2">
                <a href="#statistics" class="nav-link text-white" data-bs-toggle="pill">
                    <i class="bi bi-bar-chart"></i> Статистика
                </a>
            </li>
            <li class="nav-item mb-2">
                <a href="#settings" class="nav-link text-white" data-bs-toggle="pill">
                    <i class="bi bi-gear"></i> Настройки
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="admin-content">
    <div class="tab-content">
        <!-- Дашборд -->
        <div class="tab-pane fade show active" id="dashboard">
            <h2 class="mb-4">Главная панель</h2>
            
            <div class="row">
                <div class="col-md-3">
                    <div class="stat-card">
                        <h3>156</h3>
                        <p>Пользователей</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        <h3>45</h3>
                        <p>Тестов</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                        <h3>1,234</h3>
                        <p>Пройдено тестов</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                        <h3>78%</h3>
                        <p>Средний результат</p>
                    </div>
                </div>
            </div>
            
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>Последние регистрации</h5>
                        </div>
                        <div class="card-body">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Пользователь</th>
                                        <th>Email</th>
                                        <th>Дата</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <span class="user-avatar me-2"></span>
                                            Иван Иванов
                                        </td>
                                        <td>ivan@mail.ru</td>
                                        <td>10.03.2026</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <span class="user-avatar me-2"></span>
                                            Петр Петров
                                        </td>
                                        <td>petr@mail.ru</td>
                                        <td>09.03.2026</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>Популярные тесты</h5>
                        </div>
                        <div class="card-body">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Название</th>
                                        <th>Прохождений</th>
                                        <th>Ср. балл</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Основы Python</td>
                                        <td>234</td>
                                        <td>76%</td>
                                    </tr>
                                    <tr>
                                        <td>Математический анализ</td>
                                        <td>189</td>
                                        <td>68%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Пользователи -->
        <div class="tab-pane fade" id="users">
            <h2 class="mb-4">Управление пользователями</h2>
            
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Поиск пользователей...">
                    </div>
                    
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Имя</th>
                                <th>Email</th>
                                <th>Группа</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>Иван Иванов</td>
                                <td>ivan@mail.ru</td>
                                <td>Студент</td>
                                <td><span class="badge bg-success">Активен</span></td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Редактировать</button>
                                    <button class="btn btn-sm btn-danger">Блокировать</button>
                                </td>
                            </tr>
                            <tr>
                                <td>2</td>
                                <td>Мария Петрова</td>
                                <td>maria@mail.ru</td>
                                <td>Преподаватель</td>
                                <td><span class="badge bg-success">Активен</span></td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Редактировать</button>
                                    <button class="btn btn-sm btn-danger">Блокировать</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Управление тестами -->
        <div class="tab-pane fade" id="tests">
            <h2 class="mb-4">Управление тестами</h2>
            
            <div class="card">
                <div class="card-body">
                    <button class="btn btn-primary mb-3">Создать новый тест</button>
                    
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Название</th>
                                <th>Автор</th>
                                <th>Категория</th>
                                <th>Вопросов</th>
                                <th>Прохождений</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Основы Python</td>
                                <td>Петров П.П.</td>
                                <td>Программирование</td>
                                <td>20</td>
                                <td>234</td>
                                <td>
                                    <button class="btn btn-sm btn-warning">Редактировать</button>
                                    <button class="btn btn-sm btn-danger">Удалить</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}