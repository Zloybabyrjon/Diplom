{% extends 'base.html.twig' %}

{% block title %}Прохождение теста{% endblock %}

{% block stylesheets %}
<style>
    .question-card { background: white; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 30px; margin-bottom: 30px; }
    .question-number { display: inline-block; background: #0d6efd; color: white; width: 40px; height: 40px; border-radius: 50%; text-align: center; line-height: 40px; margin-right: 15px; font-weight: bold; }
    .answer-option { border: 2px solid #e9ecef; border-radius: 8px; padding: 15px; margin-bottom: 10px; cursor: pointer; transition: all 0.2s; }
    .answer-option:hover { border-color: #0d6efd; background-color: #f8f9fa; }
    .answer-option.selected { border-color: #198754; background-color: #d1e7dd; }
    .progress { height: 10px; margin-bottom: 20px; }
    .timer { font-size: 1.2rem; font-weight: bold; color: #dc3545; }
</style>
{% endblock %}

{% block body %}
<div class="container">
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">{{ test.title }}</h2>
                <div class="timer" id="timer">--:--</div>
            </div>
            <div class="progress mt-3">
                <div class="progress-bar" id="progressBar" style="width: 0%"></div>
            </div>
            <div class="d-flex justify-content-between">
                <small>Вопрос <span id="currentQuestion">1</span> из <span id="totalQuestions">{{ questions|length }}</span></small>
                <small>{{ test.subject ?? '' }}</small>
            </div>
        </div>
    </div>

    <form id="testForm" method="POST" action="{{ path('app_test_submit', {'id': test.id}) }}">
        <input type="hidden" name="attempt_id" value="{{ attempt.id }}">

        {% for question in questions %}
            <div class="question-card" data-question-index="{{ loop.index }}" {% if loop.index != 1 %}style="display: none;"{% endif %}>
                <div class="mb-4">
                    <span class="question-number">{{ loop.index }}</span>
                    <h4 class="d-inline">{{ question.questionText }}</h4>
                </div>

                {% if question.questionType == 'single' %}
                    {% for answer in question.answers %}
                        <div class="answer-option" data-answer-index="{{ loop.index0 }}">
                            <input type="radio"
                                   name="answers[{{ loop.parent.loop.index0 }}]"
                                   value="{{ loop.index0 }}"
                                   style="display: none;">
                            {{ answer.answerText }}
                        </div>
                    {% endfor %}
                {% else %}
                    {% for answer in question.answers %}
                        <div class="answer-option" data-answer-index="{{ loop.index0 }}">
                            <input type="checkbox"
                                   name="answers[{{ loop.parent.loop.index0 }}][]"
                                   value="{{ loop.index0 }}"
                                   style="display: none;">
                            {{ answer.answerText }}
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        {% endfor %}

        <div class="d-flex justify-content-between mt-4">
            <button type="button" class="btn btn-outline-secondary" id="prevBtn" disabled>
                <i class="bi bi-arrow-left"></i> Назад
            </button>
            <div>
                <button type="button" class="btn btn-primary" id="nextBtn">
                    Далее <i class="bi bi-arrow-right"></i>
                </button>
                <button type="submit" class="btn btn-success" id="submitBtn" style="display: none;">
                    Завершить тест
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Переменные
        let currentQuestion = 1;
        const totalQuestions = {{ questions|length }};
        const answers = {};

        // Элементы DOM
        const questionCards = document.querySelectorAll('.question-card');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        const progressBar = document.getElementById('progressBar');
        const currentQuestionSpan = document.getElementById('currentQuestion');
        const timerDiv = document.getElementById('timer');

        // Устанавливаем оставшееся время из сервера
        let timeLeft = {{ remainingSeconds }};
        function formatTime(sec) {
            const minutes = Math.floor(sec / 60);
            const seconds = sec % 60;
            return `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
        function updateTimer() {
            timerDiv.textContent = formatTime(timeLeft);
            if (timeLeft > 0) {
                timeLeft--;
                setTimeout(updateTimer, 1000);
            } else {
                document.getElementById('testForm').submit();
            }
        }
        updateTimer();

        // Функция показа текущего вопроса
        function showQuestion(index) {
            questionCards.forEach((card, i) => {
                card.style.display = (i+1 === index) ? 'block' : 'none';
            });
            const progress = ((index - 1) / totalQuestions) * 100;
            progressBar.style.width = progress + '%';
            currentQuestionSpan.textContent = index;

            prevBtn.disabled = (index === 1);
            const isLast = (index === totalQuestions);
            nextBtn.style.display = isLast ? 'none' : 'inline-block';
            submitBtn.style.display = isLast ? 'inline-block' : 'none';
        }

        // Обработка выбора ответа (радио/чекбокс)
        function handleAnswerClick(optionDiv, qIndex, aIndex, isCheckbox = false) {
            const input = optionDiv.querySelector('input');
            if (!input) return;

            if (!isCheckbox) {
                // radio: убираем выделение со всех в этом вопросе
                const parentCard = optionDiv.closest('.question-card');
                parentCard.querySelectorAll('.answer-option').forEach(opt => {
                    opt.classList.remove('selected');
                    opt.querySelector('input').checked = false;
                });
                optionDiv.classList.add('selected');
                input.checked = true;
                answers[qIndex] = [aIndex];
            } else {
                // checkbox
                optionDiv.classList.toggle('selected');
                input.checked = !input.checked;

                if (!answers[qIndex]) answers[qIndex] = [];
                if (input.checked) {
                    if (!answers[qIndex].includes(aIndex)) answers[qIndex].push(aIndex);
                } else {
                    const idx = answers[qIndex].indexOf(aIndex);
                    if (idx !== -1) answers[qIndex].splice(idx, 1);
                }
            }
        }

        // Навешиваем обработчики на все варианты ответов
        questionCards.forEach((card, qIdx) => {
            const qIndex = qIdx + 1;
            const options = card.querySelectorAll('.answer-option');
            options.forEach(option => {
                const aIndex = parseInt(option.dataset.answerIndex);
                const isCheckbox = option.querySelector('input[type="checkbox"]') !== null;
                option.addEventListener('click', (e) => {
                    e.stopPropagation();
                    handleAnswerClick(option, qIndex, aIndex, isCheckbox);
                });
            });
        });

        // Кнопки навигации
        prevBtn.addEventListener('click', () => {
            if (currentQuestion > 1) {
                currentQuestion--;
                showQuestion(currentQuestion);
            }
        });

        nextBtn.addEventListener('click', () => {
            if (currentQuestion < totalQuestions) {
                currentQuestion++;
                showQuestion(currentQuestion);
            }
        });

        // Инициализация
        showQuestion(1);
    });
</script>
{% endblock %}