{% extends 'base.html.twig' %}

{% block title %}Прохождение теста{% endblock %}

{% block stylesheets %}
<style>
    .question-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        padding: 30px;
        margin-bottom: 30px;
    }
    
    .question-number {
        display: inline-block;
        background: #0d6efd;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        text-align: center;
        line-height: 40px;
        margin-right: 15px;
        font-weight: bold;
    }
    
    .answer-option {
        border: 2px solid #e9ecef;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .answer-option:hover {
        border-color: #0d6efd;
        background-color: #f8f9fa;
    }
    
    .answer-option.selected {
        border-color: #198754;
        background-color: #d1e7dd;
    }
    
    .progress {
        height: 10px;
        margin-bottom: 20px;
    }
    
    .timer {
        font-size: 1.2rem;
        font-weight: bold;
        color: #dc3545;
    }
</style>
{% endblock %}

{% block body %}
<div class="container">
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">{{ test.title }}</h2>
                <div class="timer" id="timer">60:00</div>
            </div>
            <div class="progress mt-3">
                <div class="progress-bar" id="progressBar" style="width: 0%"></div>
            </div>
            <div class="d-flex justify-content-between">
                <small>Вопрос <span id="currentQuestion">1</span> из <span id="totalQuestions">{{ test.questions|length }}</span></small>
                <small>{{ test.subject }}</small>
            </div>
        </div>
    </div>
    
    <form id="testForm" method="POST" action="#">
        {% for question in test.questions %}
        <div class="question-card" id="question-{{ loop.index }}" {% if loop.index != 1 %}style="display: none;"{% endif %}>
            <div class="mb-4">
                <span class="question-number">{{ loop.index }}</span>
                <h4 class="d-inline">{{ question.text }}</h4>
            </div>
            
            {% if question.type == 'single' %}
                {% for answer in question.answers %}
                <div class="answer-option" onclick="selectAnswer({{ loop.index0 }}, {{ loop.parent.loop.index0 }})">
                    <input type="radio" 
                           name="answers[{{ loop.parent.loop.index0 }}]" 
                           value="{{ loop.index0 }}"
                           style="display: none;">
                    {{ answer.text }}
                </div>
                {% endfor %}
            {% else %}
                {% for answer in question.answers %}
                <div class="answer-option" onclick="toggleCheckbox(this, {{ loop.index0 }}, {{ loop.parent.loop.index0 }})">
                    <input type="checkbox" 
                           name="answers[{{ loop.parent.loop.index0 }}][]" 
                           value="{{ loop.index0 }}"
                           style="display: none;">
                    {{ answer.text }}
                </div>
                {% endfor %}
            {% endif %}
        </div>
        {% endfor %}
        
        <div class="d-flex justify-content-between mt-4">
            <button type="button" class="btn btn-outline-secondary" id="prevBtn" onclick="prevQuestion()" disabled>
                <i class="bi bi-arrow-left"></i> Назад
            </button>
            
            <div>
                <button type="button" class="btn btn-outline-primary me-2" onclick="saveProgress()">
                    Сохранить
                </button>
                <button type="button" class="btn btn-primary" id="nextBtn" onclick="nextQuestion()">
                    Далее <i class="bi bi-arrow-right"></i>
                </button>
                <button type="submit" class="btn btn-success" id="submitBtn" style="display: none;">
                    Завершить тест
                </button>
            </div>
        </div>
    </form>
</div>

<script>
let currentQuestion = 1;
const totalQuestions = {{ test.questions|length }};
let answers = {};

function updateProgress() {
    const progress = ((currentQuestion - 1) / totalQuestions) * 100;
    document.getElementById('progressBar').style.width = progress + '%';
    document.getElementById('currentQuestion').textContent = currentQuestion;
}

function showQuestion(index) {
    document.querySelectorAll('.question-card').forEach(card => {
        card.style.display = 'none';
    });
    document.getElementById(`question-${index}`).style.display = 'block';
    
    document.getElementById('prevBtn').disabled = index === 1;
    document.getElementById('nextBtn').style.display = index === totalQuestions ? 'none' : 'inline-block';
    document.getElementById('submitBtn').style.display = index === totalQuestions ? 'inline-block' : 'none';
    
    updateProgress();
}

function selectAnswer(answerIndex, questionIndex) {
    const questionDiv = document.getElementById(`question-${currentQuestion}`);
    questionDiv.querySelectorAll('.answer-option').forEach(option => {
        option.classList.remove('selected');
        option.querySelector('input[type="radio"]').checked = false;
    });
    
    const selectedOption = questionDiv.querySelectorAll('.answer-option')[answerIndex];
    selectedOption.classList.add('selected');
    selectedOption.querySelector('input[type="radio"]').checked = true;
    
    answers[questionIndex] = [answerIndex];
}

function toggleCheckbox(element, answerIndex, questionIndex) {
    element.classList.toggle('selected');
    const checkbox = element.querySelector('input[type="checkbox"]');
    checkbox.checked = !checkbox.checked;
    
    if (!answers[questionIndex]) answers[questionIndex] = [];
    
    if (checkbox.checked) {
        if (!answers[questionIndex].includes(answerIndex)) {
            answers[questionIndex].push(answerIndex);
        }
    } else {
        const index = answers[questionIndex].indexOf(answerIndex);
        if (index > -1) {
            answers[questionIndex].splice(index, 1);
        }
    }
}

function nextQuestion() {
    if (currentQuestion < totalQuestions) {
        currentQuestion++;
        showQuestion(currentQuestion);
    }
}

function prevQuestion() {
    if (currentQuestion > 1) {
        currentQuestion--;
        showQuestion(currentQuestion);
    }
}

function saveProgress() {
    // Сохранение прогресса через AJAX
    alert('Прогресс сохранен');
}

// Таймер
let timeLeft = 60 * 60; // 60 минут в секундах

function updateTimer() {
    const minutes = Math.floor(timeLeft / 60);
    const seconds = timeLeft % 60;
    document.getElementById('timer').textContent = 
        `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    
    if (timeLeft > 0) {
        timeLeft--;
        setTimeout(updateTimer, 1000);
    } else {
        document.getElementById('testForm').submit();
    }
}

// Инициализация
document.addEventListener('DOMContentLoaded', function() {
    updateTimer();
    updateProgress();
});
</script>
{% endblock %}